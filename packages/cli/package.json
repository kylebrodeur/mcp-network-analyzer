{
  "name": "mcp-network-analyzer",
  "version": "0.3.0",
  "description": "MCP server for intelligent network request capture, analysis, and API pattern discovery",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mcp-network-analyzer": "dist/cli.js",
    "netcap": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"const{rmSync}=require('fs');try{rmSync('dist',{recursive:true,force:true})}catch{}\"",
    "test": "tsx ../../test/test-mcp.ts",
    "setup": "tsx src/cli.ts setup",
    "status": "tsx src/cli.ts status",
    "reset": "tsx src/cli.ts reset",
    "serve": "tsx src/cli.ts serve"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "network-analysis",
    "api-discovery",
    "web-scraping",
    "browser-automation",
    "playwright",
    "http-interceptor",
    "rest-api",
    "claude"
  ],
  "author": "kylebrodeur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylebrodeur/mcp-network-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/kylebrodeur/mcp-network-analyzer/issues"
  },
  "homepage": "https://github.com/kylebrodeur/mcp-network-analyzer#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mcp-network-analyzer/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "commander": "^12.1.0",
    "playwright": "^1.56.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
