{
  "name": "mcp-network-analyzer-pro",
  "version": "0.1.0",
  "description": "MCP Network Analyzer Pro — HTTP/hosted transport with cloud storage support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-network-analyzer-pro": "dist/cli.js"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"const{rmSync}=require('fs');try{rmSync('dist',{recursive:true,force:true})}catch{}\"",
    "setup": "tsx src/cli.ts setup",
    "status": "tsx src/cli.ts status",
    "install-claude": "tsx src/cli.ts install-claude",
    "reset": "tsx src/cli.ts reset",
    "serve": "tsx src/cli.ts serve"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mcp-network-analyzer/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "express": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
