#!/usr/bin/env tsx
/**
 * {{toolName}} - Auto-generated API export tool
 * Generated by MCP Network Analyzer
 * 
 * Usage:
 *   tsx {{toolName}}.ts [options]
 * 
 * Options:
 *   --output <file>    Output file path (default: data.{{outputFormat}})
{{#if includeAuth}}
 *   --auth <token>     Authentication token
{{/if}}
{{#if includeRateLimiting}}
 *   --delay <ms>       Delay between requests in milliseconds (default: 1000)
{{/if}}
 */

import { writeFileSync } from 'fs';

interface ExportOptions {
  output: string;
{{#if includeAuth}}
  auth?: string;
{{/if}}
{{#if includeRateLimiting}}
  delay: number;
{{/if}}
}

{{#each patterns}}
interface {{camelCase type}}Response {
  // TODO: Define response type based on actual API response
  [key: string]: any;
}

{{/each}}

class {{toolName}} {
  private baseUrl: string;
  private options: ExportOptions;

  constructor(baseUrl: string, options: ExportOptions) {
    this.baseUrl = baseUrl;
    this.options = options;
  }

  /**
   * Make HTTP request with error handling and retry logic
   */
  private async request<T>(
    method: string,
    path: string,
    headers: Record<string, string> = {},
    body?: any
  ): Promise<T> {
    const url = \`\${this.baseUrl}\${path}\`;
    
{{#if includeAuth}}
    if (this.options.auth) {
      headers['Authorization'] = \`Bearer \${this.options.auth}\`;
    }
{{/if}}

    try {
      const response = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          ...headers,
        },
        body: body ? JSON.stringify(body) : undefined,
      });

      if (!response.ok) {
        throw new Error(\`HTTP \${response.status}: \${response.statusText}\`);
      }

      return await response.json();
    } catch (error) {
      console.error(\`Request failed for \${url}:\`, error);
      throw error;
    }
  }

{{#if includeRateLimiting}}
  /**
   * Delay execution for rate limiting
   */
  private async delay(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

{{/if}}
{{#each patterns}}
  /**
   * Fetch data from {{method}} {{pathPattern}}
   */
  async {{methodName this}}({{#if pathParams}}{{pathParams pathParams}}{{/if}}): Promise<{{camelCase type}}Response> {
    const path = \`{{pathPattern}}\`{{#if pathParams}}.replace(/:(\w+)/g, (_, key) => (arguments as any)[key]){{/if}};
    const headers: Record<string, string> = {
{{#each requiredHeaders}}
      '{{@key}}': '{{this}}',
{{/each}}
    };

    return await this.request<{{camelCase type}}Response>('{{method}}', path, headers);
  }

{{/each}}
  /**
   * Export all data
   */
  async exportAll(): Promise<void> {
    console.log('Starting export...');
    const data: any[] = [];

{{#each patterns}}
    try {
      console.log('Fetching {{type}} data...');
      const {{camelCase type}}Data = await this.{{methodName this}}();
      data.push({{camelCase type}}Data);
{{#if ../includeRateLimiting}}
      await this.delay(this.options.delay);
{{/if}}
    } catch (error) {
      console.error('Failed to fetch {{type}} data:', error);
    }

{{/each}}
    // Save data
    const output = this.options.output || 'data.{{outputFormat}}';
    console.log(\`Saving data to \${output}...\`);
    
{{#ifEquals outputFormat "json"}}
    writeFileSync(output, JSON.stringify(data, null, 2));
{{/ifEquals}}
{{#ifEquals outputFormat "csv"}}
    // TODO: Implement CSV export
    console.warn('CSV export not yet implemented');
{{/ifEquals}}
{{#ifEquals outputFormat "sqlite"}}
    // TODO: Implement SQLite export
    console.warn('SQLite export not yet implemented');
{{/ifEquals}}
    
    console.log('Export complete!');
  }
}

// Parse command line arguments
const args = process.argv.slice(2);
const options: ExportOptions = {
  output: 'data.{{outputFormat}}',
{{#if includeRateLimiting}}
  delay: 1000,
{{/if}}
};

for (let i = 0; i < args.length; i++) {
  switch (args[i]) {
    case '--output':
      options.output = args[++i];
      break;
{{#if includeAuth}}
    case '--auth':
      options.auth = args[++i];
      break;
{{/if}}
{{#if includeRateLimiting}}
    case '--delay':
      options.delay = parseInt(args[++i], 10);
      break;
{{/if}}
    case '--help':
      console.log('Usage: tsx {{toolName}}.ts [options]');
      process.exit(0);
  }
}

// Run export
const baseUrl = '{{targetUrl}}';
const exporter = new {{toolName}}(baseUrl, options);
exporter.exportAll().catch(error => {
  console.error('Export failed:', error);
  process.exit(1);
});
