{
  "name": "mcp-network-analyzer",
  "version": "0.1.0",
  "description": "MCP server for intelligent network request capture, analysis, and API pattern discovery",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-network-analyzer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index-http.ts",
    "start": "tsx src/index-http.ts",
    "prod": "node dist/index-http.js",
    "start:stdio": "node dist/index.js",
    "dev:stdio": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"const{rmSync}=require('fs');try{rmSync('dist',{recursive:true,force:true})}catch{}\"" ,
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "install-claude": "tsx scripts/install-claude.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "network-analysis",
    "api-discovery",
    "web-scraping",
    "browser-automation"
  ],
  "author": "kylebrodeur",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "express": "^5.1.0",
    "playwright": "^1.56.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
