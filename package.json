{
  "name": "mcp-network-analyzer-workspace",
  "private": true,
  "description": "Monorepo for mcp-network-analyzer (free) and mcp-network-analyzer-pro",
  "type": "module",
  "scripts": {
    "build:all": "pnpm --filter @mcp-network-analyzer/core build && pnpm --filter mcp-network-analyzer build && pnpm --filter mcp-network-analyzer-pro build",
    "type-check:all": "pnpm -r run type-check",
    "clean:all": "pnpm -r run clean",
    "test": "tsx test/test-mcp.ts"
  },
  "devDependencies": {
    "@mcp-network-analyzer/core": "workspace:*",
    "tsx": "^4.20.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.21.0"
}
