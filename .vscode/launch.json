{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch MCP Server (dev)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "mcp",
        "order": 1
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch MCP Server (build output)",
      "program": "${workspaceFolder}/dist/index.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "pnpm: build",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "mcp",
        "order": 2
      }
    }
  ]
}
